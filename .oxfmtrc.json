{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "trailingComma": "es5",
  "importOrder": ["<THIRD_PARTY_MODULES>", "", "^[.]"],
  "importOrderTypeScriptVersion": "5.0.0",
  "importOrderCaseSensitive": true,
  "sortPackageJson": { "sortScripts": false },
  "ignorePatterns": [
    "./private/**",
    "./packages/**/dist/**",
    "./packages/**/dist-types/**",
    "./packages/**/dist-es/**",
    "./packages/**/dist-cjs/**",
    "**/dist/**",
    "**/dist-types/**",
    "**/dist-es/**",
    "**/dist-cjs/**"
  ]
}
