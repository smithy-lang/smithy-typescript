{
  "name": "@smithy/service-client-documentation-generator",
  "version": "4.3.1",
  "keywords": [
    "typedocplugin"
  ],
  "homepage": "https://github.com/smithy-lang/smithy-typescript/tree/main/packages/client-documentation-generator",
  "license": "Apache-2.0",
  "author": {
    "name": "AWS SDK for JavaScript Team",
    "url": "https://aws.amazon.com/sdk-for-javascript/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/smithy-lang/smithy-typescript.git",
    "directory": "packages/client-documentation-generator"
  },
  "files": [
    "dist-*/**"
  ],
  "sideEffects": false,
  "main": "./dist-cjs/index.js",
  "module": "./dist-es/index.js",
  "types": "./dist-types/index.d.ts",
  "typesVersions": {
    "<4.5": {
      "dist-types/*": [
        "dist-types/ts3.4/*"
      ]
    }
  },
  "publishConfig": {
    "directory": ".release/package"
  },
  "scripts": {
    "build": "yarn g:tsc -p tsconfig.cjs.json && yarn g:tsc -p tsconfig.es.json && yarn g:tsc -p tsconfig.types.json",
    "build:cjs": "premove dist-cjs && yarn g:tsc -p tsconfig.cjs.json",
    "build:es": "premove dist-es && yarn g:tsc -p tsconfig.es.json",
    "build:types": "premove dist-types && yarn g:tsc -p tsconfig.types.json",
    "build:types:downlevel": "premove dist-types/ts3.4 && downlevel-dts dist-types dist-types/ts3.4",
    "clean": "premove dist-cjs dist-es dist-types",
    "stage-release": "premove .release && yarn pack && mkdir ./.release && tar zxvf ./package.tgz --directory ./.release && rm ./package.tgz",
    "test": "exit 0"
  },
  "dependencies": {
    "tslib": "^2.6.2",
    "typedoc": "0.23.23"
  },
  "devDependencies": {
    "@types/node": "^18.11.9",
    "concurrently": "7.0.0",
    "downlevel-dts": "0.10.1",
    "premove": "4.0.0"
  },
  "typedoc": {
    "entryPoint": "src/index.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
